rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Documentos de la congregación ─────────────────────────────────────────
    // Lectura: cualquier usuario autenticado.
    // Escritura: solo usuarios que pertenezcan a esa congregación
    //            (verificado cruzando con Firestore).
    match /congregation/{congId}/documentos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.exists(
            /databases/(default)/documents/congregation/$(congId)/publishers/$(request.auth.uid)
           );
    }

    // ── Territorios: imágenes y KML ───────────────────────────────────────────
    // Lectura: cualquier miembro autenticado de la app.
    // Escritura: solo miembros de esa congregación.
    match /congregation/{congId}/territories/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.exists(
            /databases/(default)/documents/congregation/$(congId)/publishers/$(request.auth.uid)
           );
    }
  }
}
