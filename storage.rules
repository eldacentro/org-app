rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Documentos de la congregación ─────────────────────────────────────────
    // Lectura y escritura: cualquier usuario autenticado de Firebase.
    // La validación de rol (elder/admin) se hace en el cliente, igual que en
    // Firestore. Mejora futura: añadir custom claims con el congId del usuario
    // y verificar `request.auth.token.congId == congId`.
    match /congregation/{congId}/documentos/{fileName} {
      allow read: if request.auth != null;
      // 15 MB cap matches the client-side limit in DialogSubirDocumento.tsx —
      // without this, the client check is purely cosmetic; anyone could
      // upload arbitrarily large files straight to Storage.
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
    }

    // ── Territorios: imágenes (.png) y geometría (.kml) ──────────────────────
    // Mismo modelo que Documentos.
    match /congregation/{congId}/territories/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Próximos eventos: foto de portada de asambleas ───────────────────────
    // Mismo modelo que Documentos. 5 MB cap: la imagen ya se comprime en el
    // cliente antes de subir (resizeImageToJpeg), así que 5 MB es generoso.
    match /congregation/{congId}/upcoming_events/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
