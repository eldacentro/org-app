rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Ficheros del módulo de Territorios (PNG del formulario, KML original).
    // Lectura/escritura para usuarios autenticados; la validación de rol se
    // hace en el cliente, igual que en el resto de features de la congregación.
    match /congregation/{congId}/territories/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
