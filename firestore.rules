rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documentos pastorales de la congregación
    match /congregation/{congId}/documentos/{docId} {
      // Cualquier usuario autenticado puede leer
      allow read: if request.auth != null;

      // Solo usuarios autenticados pueden escribir (subir, editar)
      // La validación de rol (elder/admin) se hace en el cliente;
      // para mayor seguridad añade custom claims si lo necesitas
      allow create, update: if request.auth != null;

      // Solo borrar si estás autenticado
      allow delete: if request.auth != null;
    }

    // Categorías de la congregación
    match /congregation/{congId}/documento_categorias/{catId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Módulo de Territorios ──
    // Validación de rol (responsable/elder/admin) en el cliente, igual que
    // Documentos. Los campos sensibles (direcciones "No visitar", notas) viajan
    // cifrados con la master key de la congregación. Mejora futura: acotar por
    // pertenencia a la congregación vía custom claims.
    match /congregation/{congId}/territory_zones/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territories/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_assignments/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_locations/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_campaigns/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_requests/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_notices/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_tags/{id} {
      allow read, write: if request.auth != null;
    }
    match /congregation/{congId}/territory_settings/{id} {
      allow read, write: if request.auth != null;
    }

    // ── Señal de sincronización casi-instantánea ──
    // Solo contiene nombres de tabla + timestamps de versión (cero datos,
    // el E2E sigue intacto). La escribe únicamente el backend con Admin SDK
    // (que ignora estas reglas); ningún cliente puede escribirla, así nadie
    // puede falsificar señales ni provocar tormentas de sync.
    match /congregation/{congId}/sync/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Colección para Trigger Email from Firestore ──
    match /mail/{id} {
      // Cualquier usuario autenticado puede enviar correos creando un documento
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
